
{
    "name": "pyHelloWorld2",

    "dockerComposeFile": "compose.yaml",
    "service": "pyhelloworld2",

    "remoteUser": "pydev",

    "workspaceFolder": "/workspace/pyHelloWorld",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode-remote.remote-containers",
                "ms-azuretools.vscode-containers",
                "ms-python.vscode-pylance",
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.vscode-python-envs",
                "rherre86.best-toml",
                "ms-python.autopep8"
            ]
        }
    },

    "postCreateCommand": "pip install -e ."
}